{
    "name": "yiiatom/cms",
    "description": "Atom CMS module for Yii3 Framework",
    "license": "BSD-3-Clause",
    "require": {
        "php": ">=8.2",
        "yiisoft/yii-dataview": "^1.1",
        "yiisoft/data-db": "^1.0",
        "yiisoft/db-mysql": "^2.0",
        "yiisoft/db-migration": "^2.0",
        "yiisoft/form-model": "^1.1",
        "yiisoft/user": "^2.3",
        "ramsey/uuid": "^4.9"
    },
    "autoload": {
        "psr-4": {
            "Atom\\": "src"
        }
    },
    "extra": {
        "config-plugin": {
            "params": "config/params.php",
            "di-web": "config/di-web.php",
            "events": "config/events.php",
            "routes": "config/routes.php"
        }
    }
}
